{
    "name": "xve/plesk-laravel-kit",
    "description": "Plesk extension: XVE Laravel Kit",
    "type": "library",
    "license": "proprietary",
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload-dev": {
        "psr-4": {
            "XveLaravelKit\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "config": {
        "optimize-autoloader": true
    }
}
