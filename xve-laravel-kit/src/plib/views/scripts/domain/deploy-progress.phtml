<h2>Deployment Progress</h2>

<div id="deploy-progress-container">
    <div id="progress-bar-wrap" style="background: #e0e0e0; border-radius: 4px; height: 24px; margin-bottom: 24px; overflow: hidden;">
        <div id="progress-bar" style="background: #1976d2; height: 100%; width: 0%; transition: width 0.4s ease; border-radius: 4px; display: flex; align-items: center; justify-content: center; color: #fff; font-size: 12px; font-weight: bold; min-width: 40px;"></div>
    </div>

    <table class="table" style="width: 100%;" id="steps-table">
        <thead>
            <tr>
                <th style="text-align: left; width: 30px;">#</th>
                <th style="text-align: left;">Step</th>
                <th style="text-align: left; width: 140px;">Status</th>
            </tr>
        </thead>
        <tbody id="steps-body">
            <tr><td colspan="3" style="color: #999; padding: 20px; text-align: center;">Waiting for deployment to start...</td></tr>
        </tbody>
    </table>

    <!-- Error panel (hidden initially) -->
    <div id="error-panel" style="display: none; margin-top: 24px;">
        <h3 style="color: #c62828;">Deployment Failed</h3>
        <pre id="error-message" style="background: #ffebee; border: 1px solid #ef9a9a; border-radius: 4px; padding: 12px 16px; white-space: pre-wrap; word-break: break-word; font-size: 13px; color: #b71c1c; max-height: 400px; overflow-y: auto;"></pre>
        <div style="margin-top: 12px;">
            <a id="error-detail-link" href="#" class="btn">View Full Error Details</a>
        </div>
    </div>

    <!-- Success panel (hidden initially) -->
    <div id="success-panel" style="display: none; margin-top: 24px;">
        <div style="background: #e8f5e9; border: 1px solid #a5d6a7; border-radius: 4px; padding: 16px; text-align: center;">
            <span style="font-size: 24px;">&#x2705;</span>
            <p style="margin: 8px 0 0; font-size: 15px; color: #2e7d32; font-weight: bold;">Deployment successful!</p>
            <p style="margin: 4px 0 0; color: #666;">Release: <code id="success-release"></code></p>
        </div>
    </div>

    <div style="margin-top: 20px;">
        <a href="<?php echo Modules_XveLaravelKit_Url::action('domain/releases', ['domain_id' => $this->domain->getId()]); ?>"
           class="btn" id="back-btn">&larr; Back to Releases</a>
    </div>
</div>

<script>
(function() {
    var statusUrl = <?php echo json_encode(Modules_XveLaravelKit_Url::action('domain/deploy-status', ['domain_id' => $this->domain->getId()])); ?>;
    var releasesUrl = <?php echo json_encode(Modules_XveLaravelKit_Url::action('domain/releases', ['domain_id' => $this->domain->getId()])); ?>;
    var errorBaseUrl = <?php echo json_encode(Modules_XveLaravelKit_Url::action('domain/deploy-error', ['domain_id' => $this->domain->getId(), 'release' => '__RELEASE__'])); ?>;
    var domainId = <?php echo json_encode($this->domain->getId()); ?>;

    var progressBar = document.getElementById('progress-bar');
    var stepsBody = document.getElementById('steps-body');
    var errorPanel = document.getElementById('error-panel');
    var errorMessage = document.getElementById('error-message');
    var errorDetailLink = document.getElementById('error-detail-link');
    var successPanel = document.getElementById('success-panel');
    var successRelease = document.getElementById('success-release');
    var progressBarWrap = document.getElementById('progress-bar-wrap');
    var pollTimer = null;
    var finished = false;

    var statusIcons = {
        'Completed': '&#x2705;',
        'In progress...': '&#x25B6;&#xFE0F;',
        'Failed': '&#x274C;',
        'Waiting': '&#x23F3;'
    };
    var statusColors = {
        'Completed': '#2e7d32',
        'In progress...': '#1565c0',
        'Failed': '#c62828',
        'Waiting': '#999'
    };

    function renderSteps(steps) {
        if (!steps || Object.keys(steps).length === 0) return;

        var html = '';
        var i = 1;
        for (var key in steps) {
            var step = steps[key];
            var icon = statusIcons[step.progressStatus] || '&#x23F3;';
            var color = statusColors[step.progressStatus] || '#999';
            var bg = step.progressStatus === 'Failed' ? ' style="background: #ffebee;"' : (step.progressStatus === 'In progress...' ? ' style="background: #e3f2fd;"' : '');

            html += '<tr' + bg + '>'
                + '<td style="color: #999;">' + i + '</td>'
                + '<td>' + step.title + '</td>'
                + '<td style="color: ' + color + ';">' + icon + ' ' + step.progressStatus + '</td>'
                + '</tr>';
            i++;
        }
        stepsBody.innerHTML = html;
    }

    function pollStatus() {
        if (finished) return;

        fetch(statusUrl)
            .then(function(r) { return r.json(); })
            .then(function(data) {
                // Update steps
                if (data.steps) {
                    renderSteps(data.steps);
                }

                // Update progress bar
                var pct = data.progress || 0;
                progressBar.style.width = pct + '%';
                progressBar.textContent = pct + '%';

                if (data.status === 'done') {
                    finished = true;
                    clearInterval(pollTimer);
                    progressBar.style.background = '#43a047';
                    progressBar.style.width = '100%';
                    progressBar.textContent = '100%';
                    successPanel.style.display = 'block';
                    if (data.release) {
                        successRelease.textContent = data.release;
                    }
                    // Auto-redirect to releases after 3 seconds
                    setTimeout(function() {
                        window.location.href = releasesUrl;
                    }, 3000);

                } else if (data.status === 'error') {
                    finished = true;
                    clearInterval(pollTimer);
                    progressBar.style.background = '#e53935';
                    errorPanel.style.display = 'block';
                    errorMessage.textContent = data.error || 'Unknown error';
                    if (data.release) {
                        errorDetailLink.href = errorBaseUrl.replace('__RELEASE__', encodeURIComponent(data.release));
                    }
                }
            })
            .catch(function() {});
    }

    pollTimer = setInterval(pollStatus, 1500);
    pollStatus();
})();
</script>
