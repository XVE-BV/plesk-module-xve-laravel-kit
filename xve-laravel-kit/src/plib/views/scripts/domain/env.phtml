<?php echo $this->renderTabs($this->tabs); ?>

<?php if (empty($this->envContents) && !empty($this->envExample)): ?>
    <div class="msg-box msg-warning">
        <p>No <code>.env</code> file found in <code>shared/</code>. The template below is loaded from <code>.env.example</code>. Edit and save to create it.</p>
    </div>
<?php endif; ?>

<?php if (!empty($this->validationIssues)): ?>
    <div style="margin-bottom: 15px; padding: 12px 16px; border-radius: 4px; border: 1px solid <?php echo !empty($this->hasErrors) ? '#e74c3c' : '#f39c12'; ?>; background: <?php echo !empty($this->hasErrors) ? '#fdf0ef' : '#fef9e7'; ?>;">
        <strong style="display: block; margin-bottom: 8px;">
            <?php echo !empty($this->hasErrors) ? 'Validation errors — please fix before saving:' : 'Warnings found — review before saving:'; ?>
        </strong>
        <ul style="margin: 0; padding-left: 20px;">
            <?php foreach ($this->validationIssues as $issue): ?>
                <li style="margin-bottom: 4px; color: <?php echo $issue['level'] === 'error' ? '#c0392b' : '#856404'; ?>;">
                    <?php if ($issue['level'] === 'error'): ?>
                        <strong>Error:</strong>
                    <?php else: ?>
                        <strong>Warning:</strong>
                    <?php endif; ?>
                    <?php echo $this->escape($issue['message']); ?>
                </li>
            <?php endforeach; ?>
        </ul>
    </div>
<?php endif; ?>

<form method="post" action="<?php echo Modules_XveLaravelKit_Url::action('domain/env', ['domain_id' => $this->domain->getId()]); ?>">
    <div style="margin-bottom: 15px;">
        <label style="font-weight: bold; display: block; margin-bottom: 5px;">shared/.env</label>
        <textarea name="env_contents" rows="30"
                  style="width: 100%; max-width: 900px; font-family: monospace; font-size: 13px; padding: 10px; border: 1px solid <?php echo !empty($this->hasErrors) ? '#e74c3c' : '#ccc'; ?>; background: #fafafa; tab-size: 4;"
        ><?php echo $this->escape(!empty($this->envContents) ? $this->envContents : $this->envExample); ?></textarea>
    </div>
    <div style="margin-bottom: 12px;">
        <label style="cursor: pointer;">
            <input type="checkbox" name="config_cache" value="1" <?php echo (!isset($this->configCache) || $this->configCache) ? 'checked' : ''; ?> />
            Run <code>php artisan config:cache</code> after saving
        </label>
    </div>
    <?php if (!empty($this->validationIssues) && empty($this->hasErrors)): ?>
        <input type="hidden" name="force_save" value="1" />
        <button type="submit" class="btn btn-primary"
                onclick="return confirm('Save despite warnings? A backup of the current file will be created.');">
            Save anyway
        </button>
    <?php else: ?>
        <button type="submit" class="btn btn-primary"
                onclick="return confirm('Save .env file? A backup of the current file will be created.');">
            Save .env
        </button>
    <?php endif; ?>
</form>
