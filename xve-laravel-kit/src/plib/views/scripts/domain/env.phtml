<?php echo $this->renderTabs($this->tabs); ?>

<?php if (empty($this->envContents) && !empty($this->envExample)): ?>
    <div class="msg-box msg-warning">
        <p>No <code>.env</code> file found in <code>shared/</code>. The template below is loaded from <code>.env.example</code>. Edit and save to create it.</p>
    </div>
<?php endif; ?>

<form method="post" action="<?php echo Modules_XveLaravelKit_Url::action('domain/env', ['domain_id' => $this->domain->getId()]); ?>">
    <div style="margin-bottom: 15px;">
        <label style="font-weight: bold; display: block; margin-bottom: 5px;">shared/.env</label>
        <textarea name="env_contents" rows="30"
                  style="width: 100%; max-width: 900px; font-family: monospace; font-size: 13px; padding: 10px; border: 1px solid #ccc; background: #fafafa; tab-size: 4;"
        ><?php echo $this->escape(!empty($this->envContents) ? $this->envContents : $this->envExample); ?></textarea>
    </div>
    <div style="margin-bottom: 12px;">
        <label style="cursor: pointer;">
            <input type="checkbox" name="config_cache" value="1" checked />
            Run <code>php artisan config:cache</code> after saving
        </label>
    </div>
    <button type="submit" class="btn btn-primary"
            onclick="return confirm('Save .env file? A backup of the current file will be created.');">
        Save .env
    </button>
</form>
