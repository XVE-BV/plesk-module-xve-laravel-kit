<h2>Deployment History: <?php echo $this->escape($this->domain->getDisplayName()); ?></h2>

<div style="margin-bottom: 20px;">
    <a href="<?php echo Modules_XveLaravelKit_Url::action('domain/index', ['domain_id' => $this->domain->getId()]); ?>"
       class="btn">&larr; Back</a>
</div>

<?php if (empty($this->history)): ?>
    <p>No deployment history yet.</p>
<?php else: ?>
    <table class="table" style="width: 100%;">
        <thead>
            <tr>
                <th style="text-align: left;">Timestamp</th>
                <th style="text-align: left;">Release</th>
                <th style="text-align: left;">Commit</th>
                <th style="text-align: left;">Action</th>
                <th style="text-align: left;">Status</th>
                <th style="text-align: left;">User</th>
            </tr>
        </thead>
        <tbody>
            <?php foreach ($this->history as $entry):
                $bg = ($entry['status'] === 'failed') ? '#ffebee' : '';
                $commit = isset($entry['commit']) ? $entry['commit'] : null;
            ?>
                <tr<?php echo $bg ? ' style="background: ' . $bg . ';"' : ''; ?>>
                    <td style="white-space: nowrap;"><?php echo $this->escape($entry['timestamp']); ?></td>
                    <td><code><?php echo $this->escape($entry['release']); ?></code></td>
                    <td style="white-space: nowrap;">
                        <?php if ($commit): ?>
                            <?php if ($this->repoWebUrl): ?>
                                <a href="<?php echo $this->escape($this->repoWebUrl . '/commit/' . $commit['hash']); ?>" target="_blank" style="text-decoration: none;"><code><?php echo $this->escape(substr($commit['hash'], 0, 7)); ?></code></a>
                            <?php else: ?>
                                <code><?php echo $this->escape(substr($commit['hash'], 0, 7)); ?></code>
                            <?php endif; ?>
                            <span style="color: #666; font-size: 12px;"><?php echo $this->escape($commit['branch']); ?></span>
                            <br><span style="color: #888; font-size: 12px;"><?php echo $this->escape(mb_strimwidth($commit['message'], 0, 50, '...')); ?></span>
                        <?php else: ?>
                            <span style="color: #ccc;">&mdash;</span>
                        <?php endif; ?>
                    </td>
                    <td><?php echo $this->escape($entry['action']); ?></td>
                    <td>
                        <?php echo $entry['status'] === 'success' ? '&#x2705;' : '&#x274C;'; ?> <?php echo $this->escape($entry['status']); ?>
                        <?php if ($entry['status'] === 'failed'): ?>
                            <a href="<?php echo Modules_XveLaravelKit_Url::action('domain/deploy-error', ['domain_id' => $this->domain->getId(), 'release' => $entry['release']]); ?>"
                               style="font-size: 11px; margin-left: 4px;">View Error</a>
                        <?php endif; ?>
                    </td>
                    <td><?php echo $this->escape($entry['user'] ?? '—'); ?></td>
                </tr>
            <?php endforeach; ?>
        </tbody>
    </table>
<?php endif; ?>
