<h2>Deployment History: <?php echo $this->escape($this->domain->getDisplayName()); ?></h2>

<div style="margin-bottom: 20px;">
    <a href="<?php echo Modules_XveLaravelKit_Url::action('domain/index', ['domain_id' => $this->domain->getId()]); ?>"
       class="btn">&larr; Back</a>
</div>

<?php if (empty($this->history)): ?>
    <p>No deployment history yet.</p>
<?php else: ?>
    <table class="table" style="width: 100%; max-width: 800px;">
        <thead>
            <tr><th>Timestamp</th><th>Release</th><th>Action</th><th>Status</th><th>User</th></tr>
        </thead>
        <tbody>
            <?php foreach ($this->history as $entry):
                $bg = ($entry['status'] === 'failed') ? '#ffebee' : '';
            ?>
                <tr<?php echo $bg ? ' style="background: ' . $bg . ';"' : ''; ?>>
                    <td style="white-space: nowrap;"><?php echo $this->escape($entry['timestamp']); ?></td>
                    <td><code><?php echo $this->escape($entry['release']); ?></code></td>
                    <td><?php echo $this->escape($entry['action']); ?></td>
                    <td><?php echo $entry['status'] === 'success' ? '&#x2705;' : '&#x274C;'; ?> <?php echo $this->escape($entry['status']); ?></td>
                    <td><?php echo $this->escape($entry['user'] ?? '—'); ?></td>
                </tr>
            <?php endforeach; ?>
        </tbody>
    </table>
<?php endif; ?>
