<script>
function xlkReadAuthFile(input) {
    var file = input.files[0];
    if (!file) return;
    var reader = new FileReader();
    reader.onload = function(e) {
        try {
            JSON.parse(e.target.result);
            document.getElementById('xlk-auth-json-contents').value = e.target.result;
            document.getElementById('xlk-auth-file-name').textContent = file.name;
            var btn = document.getElementById('xlk-auth-submit');
            btn.disabled = false;
            btn.style.opacity = '1';
        } catch (err) {
            alert('Invalid JSON file: ' + err.message);
            input.value = '';
        }
    };
    reader.readAsText(file);
}
</script>

